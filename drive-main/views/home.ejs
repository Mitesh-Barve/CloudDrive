<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - CloudDrive</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.4.0/fonts/remixicon.css" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            background: #0F0F0F;
            color: #FAFAFA;
        }

        /* ── Sidebar ─────────────────────────────── */
        .sidebar {
            position: fixed;
            left: 0; top: 0;
            width: 240px; height: 100vh;
            background: #1A1A1A;
            border-right: 1px solid #2a2a2a;
            padding: 28px 16px;
            display: flex; flex-direction: column;
            z-index: 100;
        }

        .sidebar-scrollable { flex: 1; overflow-y: auto; margin-bottom: 16px; }
        .sidebar-scrollable::-webkit-scrollbar { width: 3px; }
        .sidebar-scrollable::-webkit-scrollbar-thumb { background: #333; border-radius: 4px; }

        .logo { display: flex; align-items: center; gap: 10px; margin-bottom: 36px; padding: 0 8px; }

        .logo-icon {
            width: 36px; height: 36px;
            background: rgba(249, 115, 22, 0.12);
            border: 1px solid rgba(249, 115, 22, 0.25);
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
        }

        .logo-icon i { font-size: 18px; color: #F97316; }
        .logo-text { font-size: 17px; font-weight: 600; color: #FAFAFA; }

        .nav-section { margin-bottom: 28px; }

        .nav-title {
            font-size: 10px; font-weight: 600; color: #555;
            text-transform: uppercase; letter-spacing: 1.2px;
            padding: 0 12px; margin-bottom: 8px;
        }

        .nav-item {
            display: flex; align-items: center; gap: 10px;
            padding: 10px 12px; border-radius: 8px;
            color: #A1A1AA; text-decoration: none;
            font-size: 13px; font-weight: 500;
            transition: all 0.15s; margin-bottom: 2px; cursor: pointer;
        }

        .nav-item:hover { background: #222; color: #FAFAFA; }

        .nav-item.active {
            background: rgba(249, 115, 22, 0.1);
            color: #F97316;
            border: 1px solid rgba(249, 115, 22, 0.2);
        }

        .nav-item i { font-size: 16px; }
        .nav-item.logout { color: #A1A1AA; }
        .nav-item.logout:hover { background: rgba(239, 68, 68, 0.08); color: #f87171; }

        /* Storage */
        .storage-section {
            padding: 16px;
            background: rgba(249, 115, 22, 0.05);
            border-radius: 10px;
            border: 1px solid #2a2a2a;
        }

        .storage-title {
            font-size: 11px; font-weight: 600; color: #A1A1AA;
            margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.6px;
        }

        .storage-bar {
            height: 4px; background: #222;
            border-radius: 4px; overflow: hidden; margin-bottom: 8px;
        }

        .storage-fill {
            height: 100%; background: #F97316;
            border-radius: 4px; transition: width 0.5s ease;
        }

        .storage-text { font-size: 11px; color: #A1A1AA; }

        /* ── Main Content ─────────────────────────── */
        .main-content {
            margin-left: 240px;
            padding: 32px 40px;
            min-height: 100vh;
        }

        .header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 36px; flex-wrap: wrap; gap: 16px;
        }

        .page-title { font-size: 24px; font-weight: 600; color: #FAFAFA; letter-spacing: -0.4px; }

        .upload-btn {
            display: flex; align-items: center; gap: 8px;
            padding: 11px 22px; background: #F97316;
            border: none; border-radius: 8px;
            color: #0F0F0F; font-size: 13px; font-weight: 700;
            cursor: pointer; transition: all 0.25s;
            font-family: 'Inter', sans-serif;
        }

        .upload-btn:hover {
            background: #EA580C;
            box-shadow: 0 0 24px rgba(249, 115, 22, 0.35);
        }

        .upload-btn:disabled { opacity: 0.4; cursor: not-allowed; box-shadow: none; }
        .upload-btn i { font-size: 16px; }

        .file-count {
            font-size: 12px; color: #A1A1AA;
            background: #1A1A1A; border: 1px solid #2a2a2a;
            padding: 5px 12px; border-radius: 20px;
            margin-bottom: 24px; display: inline-block;
        }

        /* ── Files Grid ──────────────────────────── */
        .files-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 14px;
        }

        .file-card {
            background: #1A1A1A;
            border: 1px solid #2a2a2a;
            border-radius: 10px;
            padding: 18px 20px;
            display: flex; align-items: center; gap: 16px;
            transition: border-color 0.2s, background 0.2s;
        }

        .file-card:hover { background: #1f1f1f; border-color: #3a3a3a; }

        .file-icon {
            width: 44px; height: 44px;
            background: rgba(249, 115, 22, 0.08);
            border: 1px solid rgba(249, 115, 22, 0.15);
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }

        .file-icon i { font-size: 20px; color: #F97316; }

        .file-icon.pdf { background: rgba(239, 68, 68, 0.08); border-color: rgba(239, 68, 68, 0.2); }
        .file-icon.pdf i { color: #f87171; }

        .file-icon.image { background: rgba(59, 130, 246, 0.08); border-color: rgba(59, 130, 246, 0.2); }
        .file-icon.image i { color: #60a5fa; }

        .file-icon.doc { background: rgba(34, 197, 94, 0.08); border-color: rgba(34, 197, 94, 0.2); }
        .file-icon.doc i { color: #4ade80; }

        .file-info { flex: 1; min-width: 0; }

        .file-name {
            font-size: 13px; font-weight: 500; color: #FAFAFA;
            margin-bottom: 4px; display: block;
            overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
        }

        .file-meta {
            font-size: 11px; color: #A1A1AA;
            display: flex; align-items: center; gap: 5px;
        }

        .file-meta i { font-size: 11px; }
        .file-actions { display: flex; gap: 6px; flex-shrink: 0; }

        .action-btn {
            width: 34px; height: 34px; border-radius: 6px;
            border: 1px solid #2a2a2a; background: #0F0F0F;
            color: #A1A1AA; cursor: pointer;
            transition: all 0.2s;
            display: flex; align-items: center; justify-content: center;
            text-decoration: none;
        }

        .action-btn:hover {
            background: rgba(249, 115, 22, 0.1);
            color: #F97316;
            border-color: rgba(249, 115, 22, 0.3);
        }

        .action-btn.delete:hover {
            background: rgba(239, 68, 68, 0.1);
            color: #f87171;
            border-color: rgba(239, 68, 68, 0.3);
        }

        .action-btn i { font-size: 15px; }
        .action-btn.active i { color: #fbbf24 !important; }

        /* ── Empty State ─────────────────────────── */
        .empty-state {
            text-align: center; padding: 80px 20px;
            background: #1A1A1A; border-radius: 12px;
            border: 1px dashed #333;
        }

        .empty-icon {
            width: 72px; height: 72px;
            background: rgba(249, 115, 22, 0.08);
            border: 1px solid rgba(249, 115, 22, 0.15);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 20px;
        }

        .empty-icon i { font-size: 28px; color: #F97316; }
        .empty-title { font-size: 18px; font-weight: 600; color: #FAFAFA; margin-bottom: 8px; }
        .empty-text { color: #A1A1AA; font-size: 13px; margin-bottom: 24px; }
        .empty-state .upload-btn { width: auto; margin: 0 auto; }

        /* ── Upload Modal ────────────────────────── */
        .modal-overlay {
            display: none; position: fixed; inset: 0;
            background: rgba(0, 0, 0, 0.8);
            z-index: 1000; align-items: center; justify-content: center;
        }

        .modal-overlay.active { display: flex; }

        .modal {
            background: #1A1A1A; border-radius: 14px; padding: 40px;
            width: 90%; max-width: 460px;
            border: 1px solid #2a2a2a; position: relative;
        }

        .modal-close {
            position: absolute; top: 18px; right: 18px;
            width: 32px; height: 32px; border-radius: 6px;
            border: 1px solid #2a2a2a; background: #0F0F0F;
            color: #A1A1AA; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            font-size: 18px; transition: all 0.2s;
        }

        .modal-close:hover { color: #f87171; border-color: rgba(239, 68, 68, 0.4); }

        .modal-title { font-size: 20px; font-weight: 600; color: #FAFAFA; margin-bottom: 28px; }

        .dropzone {
            width: 100%; border: 1px dashed #333;
            border-radius: 10px; padding: 40px 24px;
            text-align: center; cursor: pointer;
            transition: all 0.2s; margin-bottom: 20px;
            display: flex; flex-direction: column; align-items: center;
        }

        .dropzone:hover, .dropzone.dragover {
            border-color: #F97316;
            background: rgba(249, 115, 22, 0.04);
        }

        .dropzone i { font-size: 36px; color: #F97316; margin-bottom: 12px; opacity: 0.5; }
        .dropzone-text { font-size: 14px; color: #A1A1AA; margin-bottom: 6px; font-weight: 500; }
        .dropzone-hint { font-size: 12px; color: #555; }

        .modal-submit {
            width: 100%; padding: 13px;
            background: #F97316; border: none; border-radius: 8px;
            color: #0F0F0F; font-size: 14px; font-weight: 700;
            cursor: pointer; transition: all 0.25s;
            display: flex; align-items: center; justify-content: center; gap: 10px;
            font-family: 'Inter', sans-serif;
        }

        .modal-submit:hover:not(:disabled) { background: #EA580C; box-shadow: 0 0 24px rgba(249, 115, 22, 0.35); }
        .modal-submit:disabled { opacity: 0.4; cursor: not-allowed; }

        .spinner {
            width: 16px; height: 16px;
            border: 2px solid rgba(15, 15, 15, 0.3);
            border-top-color: #0F0F0F; border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin { to { transform: rotate(360deg); } }

        /* ── Toast ───────────────────────────────── */
        .toast-container {
            position: fixed; top: 20px; right: 20px;
            z-index: 2000; display: flex; flex-direction: column; gap: 8px;
        }

        .toast {
            background: #1A1A1A; border: 1px solid #2a2a2a;
            border-radius: 8px; padding: 12px 18px;
            display: flex; align-items: center; gap: 10px;
            color: #FAFAFA; font-size: 13px; font-weight: 500;
            animation: slideIn 0.25s ease;
        }

        .toast.success { border-left: 3px solid #F97316; }
        .toast.error { border-left: 3px solid #ef4444; }
        .toast i { font-size: 16px; }
        .toast.success i { color: #F97316; }
        .toast.error i { color: #f87171; }

        @keyframes slideIn {
            from { transform: translateX(60px); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        /* ── Delete Confirm ──────────────────────── */
        .confirm-modal {
            display: none; position: fixed; inset: 0;
            background: rgba(0, 0, 0, 0.8);
            z-index: 1001; align-items: center; justify-content: center;
        }

        .confirm-modal.active { display: flex; }

        .confirm-box {
            background: #1A1A1A; border-radius: 12px; padding: 32px;
            width: 90%; max-width: 380px; text-align: center;
            border: 1px solid #2a2a2a;
        }

        .confirm-icon {
            width: 52px; height: 52px;
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.25);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 18px;
        }

        .confirm-icon i { font-size: 22px; color: #f87171; }
        .confirm-title { font-size: 17px; font-weight: 600; color: #FAFAFA; margin-bottom: 8px; }
        .confirm-text { color: #A1A1AA; font-size: 13px; margin-bottom: 24px; }

        .confirm-actions { display: flex; gap: 10px; }

        .confirm-btn {
            flex: 1; padding: 12px; border-radius: 8px;
            border: 1px solid #2a2a2a; font-size: 13px; font-weight: 600;
            cursor: pointer; transition: all 0.2s; font-family: 'Inter', sans-serif;
        }

        .confirm-btn.cancel { background: #0F0F0F; color: #A1A1AA; }
        .confirm-btn.cancel:hover { background: #1f1f1f; color: #FAFAFA; }
        .confirm-btn.delete { background: rgba(239, 68, 68, 0.12); color: #f87171; border-color: rgba(239, 68, 68, 0.3); }
        .confirm-btn.delete:hover { background: rgba(239, 68, 68, 0.22); }

        /* ── Responsive ──────────────────────────── */
        @media (max-width: 960px) {
            .sidebar { transform: translateX(-100%); }
            .main-content { margin-left: 0; padding: 24px 20px; }
            .files-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <div class="toast-container" id="toastContainer"></div>

    <aside class="sidebar">
        <div class="logo">
            <div class="logo-icon"><i class="ri-cloud-line"></i></div>
            <span class="logo-text">CloudDrive</span>
        </div>

        <div class="sidebar-scrollable">
            <nav class="nav-section">
                <div class="nav-title">Main</div>
                <a href="/home" class="nav-item <%= filter === 'all' || !filter ? 'active' : '' %>">
                    <i class="ri-dashboard-line"></i><span>Dashboard</span>
                </a>
                <a href="/home?filter=all" class="nav-item">
                    <i class="ri-folder-line"></i><span>My Files</span>
                </a>
                <a href="/home?filter=favorites" class="nav-item <%= filter === 'favorites' ? 'active' : '' %>">
                    <i class="ri-star-line"></i><span>Favorites</span>
                </a>
                <a href="/home?filter=recent" class="nav-item <%= filter === 'recent' ? 'active' : '' %>">
                    <i class="ri-time-line"></i><span>Recent</span>
                </a>
            </nav>
            <nav class="nav-section">
                <div class="nav-title">Account</div>
                <a href="#" class="nav-item">
                    <i class="ri-settings-3-line"></i><span>Settings</span>
                </a>
                <a href="/logout" class="nav-item logout">
                    <i class="ri-logout-box-line"></i><span>Logout</span>
                </a>
            </nav>
        </div>

        <div class="storage-section">
            <div class="storage-title">Storage</div>
            <div class="storage-bar">
                <div class="storage-fill" style="width: <%= Math.min((files.length / 15) * 100, 100) %>%"></div>
            </div>
            <div class="storage-text"><%= files ? files.length : 0 %> / 15 files</div>
        </div>
    </aside>

    <main class="main-content">
        <header class="header">
            <h1 class="page-title">
                <%= filter==='favorites' ? 'Favorites' : (filter==='recent' ? 'Recent' : 'My Files') %>
            </h1>
            <div>
                <button class="upload-btn" onclick="showModal()" id="uploadTrigger">
                    <i class="ri-upload-2-line"></i> Upload File
                </button>
            </div>
        </header>

        <section class="files-section">
            <div><span class="file-count"><%= files ? files.length : 0 %> files</span></div>

            <% if (files && files.length > 0) { %>
                <div class="files-grid">
                    <% files.forEach((file) => {
                        const ext = file.originalname.split('.').pop().toLowerCase();
                        let iconClass = '';
                        let icon = 'ri-file-3-line';
                        if (['pdf'].includes(ext)) { iconClass = 'pdf'; icon = 'ri-file-pdf-2-line'; }
                        else if (['jpg','jpeg','png','gif','webp','svg'].includes(ext)) { iconClass = 'image'; icon = 'ri-image-line'; }
                        else if (['doc','docx','txt'].includes(ext)) { iconClass = 'doc'; icon = 'ri-file-text-line'; }
                    %>
                        <div class="file-card">
                            <div class="file-icon <%= iconClass %>"><i class="<%= icon %>"></i></div>
                            <div class="file-info">
                                <div class="file-name" title="<%= file.originalname %>"><%= file.originalname %></div>
                                <div class="file-meta">
                                    <i class="ri-calendar-line"></i>
                                    <%= new Date(file.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                                </div>
                            </div>
                            <div class="file-actions">
                                <button class="action-btn <%= file.isFavorite ? 'active' : '' %>"
                                    onclick="toggleFavorite('<%= file._id %>')" title="Favorite">
                                    <i class="<%= file.isFavorite ? 'ri-star-fill' : 'ri-star-line' %>"
                                        style="<%= file.isFavorite ? 'color: #fbbf24' : '' %>"></i>
                                </button>
                                <a href="/download/<%= file.path %>" class="action-btn" title="Download">
                                    <i class="ri-download-2-line"></i>
                                </a>
                                <button class="action-btn delete"
                                    onclick="confirmDelete('<%= file.path %>', '<%= file.originalname %>')" title="Delete">
                                    <i class="ri-delete-bin-6-line"></i>
                                </button>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <div class="empty-icon"><i class="ri-folder-open-line"></i></div>
                    <h3 class="empty-title">No files here</h3>
                    <p class="empty-text">Upload a file to get started</p>
                    <button class="upload-btn" onclick="showModal()">
                        <i class="ri-upload-2-line"></i> Upload File
                    </button>
                </div>
            <% } %>
        </section>
    </main>

    <div class="modal-overlay" id="uploadModal">
        <div class="modal">
            <button class="modal-close" onclick="hideModal()"><i class="ri-close-line"></i></button>
            <h2 class="modal-title">Upload File</h2>
            <form action="/upload" method="post" enctype="multipart/form-data" id="uploadForm">
                <label class="dropzone" for="fileInput" id="dropzone">
                    <i class="ri-upload-cloud-2-line"></i>
                    <div class="dropzone-text" id="dropzoneText">Click to browse or drag & drop</div>
                    <div class="dropzone-hint">Any file type supported</div>
                    <input type="file" id="fileInput" name="file" style="display:none;" required>
                </label>
                <button type="submit" class="modal-submit" id="submitBtn">
                    <span id="submitText">Upload File</span>
                </button>
            </form>
        </div>
    </div>

    <div class="confirm-modal" id="deleteModal">
        <div class="confirm-box">
            <div class="confirm-icon"><i class="ri-delete-bin-6-line"></i></div>
            <h3 class="confirm-title">Delete File?</h3>
            <p class="confirm-text" id="deleteFileName">This action cannot be undone.</p>
            <div class="confirm-actions">
                <button class="confirm-btn cancel" onclick="hideDeleteModal()">Cancel</button>
                <form id="deleteForm" method="post" style="flex:1;">
                    <button type="submit" class="confirm-btn delete" style="width:100%;">Delete</button>
                </form>
            </div>
        </div>
    </div>

    <script>
        function showModal() { document.getElementById('uploadModal').classList.add('active'); }
        function hideModal() {
            document.getElementById('uploadModal').classList.remove('active');
            document.getElementById('dropzoneText').textContent = 'Click to browse or drag & drop';
            document.getElementById('fileInput').value = '';
        }

        document.getElementById('uploadModal').addEventListener('click', function(e) { if (e.target === this) hideModal(); });

        document.getElementById('fileInput').addEventListener('change', function(e) {
            const name = e.target.files[0]?.name;
            if (name) document.getElementById('dropzoneText').textContent = name;
        });

        const dropzone = document.getElementById('dropzone');
        dropzone.addEventListener('dragover', (e) => { e.preventDefault(); dropzone.classList.add('dragover'); });
        dropzone.addEventListener('dragleave', () => dropzone.classList.remove('dragover'));
        dropzone.addEventListener('drop', (e) => {
            e.preventDefault(); dropzone.classList.remove('dragover');
            if (e.dataTransfer.files.length) {
                document.getElementById('fileInput').files = e.dataTransfer.files;
                document.getElementById('dropzoneText').textContent = e.dataTransfer.files[0].name;
            }
        });

        document.getElementById('uploadForm').addEventListener('submit', function() {
            document.getElementById('submitBtn').disabled = true;
            document.getElementById('submitText').innerHTML = '<div class="spinner"></div> Uploading...';
        });

        function confirmDelete(path, name) {
            document.getElementById('deleteForm').action = '/delete/' + encodeURIComponent(path);
            document.getElementById('deleteFileName').textContent = 'Delete "' + name + '"? This cannot be undone.';
            document.getElementById('deleteModal').classList.add('active');
        }

        function hideDeleteModal() { document.getElementById('deleteModal').classList.remove('active'); }
        document.getElementById('deleteModal').addEventListener('click', function(e) { if (e.target === this) hideDeleteModal(); });

        function showToast(message, type = 'success') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = 'toast ' + type;
            toast.innerHTML = '<i class="' + (type === 'success' ? 'ri-check-line' : 'ri-error-warning-line') + '"></i>' + message;
            container.appendChild(toast);
            setTimeout(() => toast.remove(), 4000);
        }

        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('uploaded') === 'true') showToast('File uploaded successfully!');
        if (urlParams.get('deleted') === 'true') showToast('File deleted successfully!');

        async function toggleFavorite(fileId) {
            try {
                const response = await fetch('/favorite/' + fileId, { method: 'POST' });
                const data = await response.json();
                if (data.success) location.reload();
                else showToast('Failed to update favorite', 'error');
            } catch (err) { showToast('An error occurred', 'error'); }
        }
    </script>
</body>
</html>