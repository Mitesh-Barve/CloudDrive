<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In - CloudDrive</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.4.0/fonts/remixicon.css" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #0F0F0F url('/bg.png') center center / cover no-repeat;
            padding: 20px;
            position: relative;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background: rgba(10, 8, 6, 0.72);
            z-index: 0;
        }

        .container {
            display: flex;
            width: 100%;
            max-width: 960px;
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid rgba(249, 115, 22, 0.15);
            box-shadow: 0 0 60px rgba(0,0,0,0.7), 0 0 30px rgba(249, 115, 22, 0.05);
            position: relative;
            z-index: 1;
        }

        .brand-section {
            flex: 1;
            background: #1A1A1A;
            padding: 60px 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            border-right: 1px solid #2a2a2a;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 48px;
        }

        .logo-icon {
            width: 40px; height: 40px;
            background: rgba(249, 115, 22, 0.12);
            border: 1px solid rgba(249, 115, 22, 0.25);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .logo-icon i { font-size: 20px; color: #F97316; }
        .logo-text { font-size: 20px; font-weight: 600; color: #FAFAFA; letter-spacing: -0.3px; }

        .brand-title { font-size: 30px; font-weight: 700; color: #FAFAFA; margin-bottom: 16px; line-height: 1.25; }
        .brand-description { font-size: 14px; color: #A1A1AA; line-height: 1.7; }

        .brand-features { margin-top: 40px; display: flex; flex-direction: column; gap: 14px; }

        .feature-item {
            display: flex; align-items: center; gap: 12px;
            color: #A1A1AA; font-size: 13px;
        }

        .feature-item i { font-size: 16px; color: #F97316; }

        .form-section {
            flex: 1;
            background: #0F0F0F;
            padding: 60px 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .form-title { font-size: 26px; font-weight: 600; color: #FAFAFA; margin-bottom: 6px; }
        .form-subtitle { color: #A1A1AA; margin-bottom: 36px; font-size: 13px; }
        .form-subtitle a {
            color: #F97316; text-decoration: none; font-weight: 500;
            transition: color 0.2s, text-shadow 0.2s;
        }
        .form-subtitle a:hover { color: #ff8c3a; text-shadow: 0 0 12px rgba(249, 115, 22, 0.4); }

        .form-group { margin-bottom: 20px; }

        .form-label {
            display: block; color: #A1A1AA; font-size: 11px;
            font-weight: 600; margin-bottom: 8px;
            text-transform: uppercase; letter-spacing: 0.8px;
        }

        .form-input {
            width: 100%; padding: 13px 16px;
            background: #1A1A1A; border: 1px solid #2a2a2a;
            border-radius: 8px; color: #FAFAFA; font-size: 14px;
            outline: none; transition: all 0.2s;
            font-family: 'Inter', sans-serif;
        }

        .form-input::placeholder { color: #444; }

        .form-input:focus {
            border-color: #F97316;
            box-shadow: 0 0 0 2px rgba(249, 115, 22, 0.12);
        }

        .submit-btn {
            width: 100%; padding: 14px;
            background: #F97316; border: none; border-radius: 8px;
            color: #0F0F0F; font-size: 14px; font-weight: 700;
            cursor: pointer; transition: all 0.25s;
            display: flex; align-items: center; justify-content: center; gap: 10px;
            margin-top: 8px; font-family: 'Inter', sans-serif;
        }

        .submit-btn:hover:not(:disabled) {
            background: #EA580C;
            box-shadow: 0 0 24px rgba(249, 115, 22, 0.35);
        }

        .submit-btn:disabled { opacity: 0.5; cursor: not-allowed; }

        .spinner {
            width: 16px; height: 16px;
            border: 2px solid rgba(15, 15, 15, 0.3);
            border-top-color: #0F0F0F;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin { to { transform: rotate(360deg); } }

        .toast {
            position: fixed; top: 24px; right: 24px;
            background: #1A1A1A; padding: 14px 20px; border-radius: 8px;
            color: #FAFAFA; display: flex; align-items: center; gap: 10px;
            border: 1px solid #2a2a2a; transform: translateX(120%);
            transition: transform 0.3s ease; z-index: 1000; font-size: 13px;
        }

        .toast.active { transform: translateX(0); }
        .toast.error { border-left: 3px solid #ef4444; }
        .toast.success { border-left: 3px solid #F97316; }

        @media (max-width: 850px) {
            .container { flex-direction: column; max-width: 420px; }
            .brand-section, .form-section { padding: 40px 36px; }
            .brand-section { border-right: none; border-bottom: 1px solid #2a2a2a; }
            .brand-features { display: none; }
        }
    </style>
</head>
<body>
    <div id="toast" class="toast">
        <i id="toastIcon"></i>
        <span id="toastMessage"></span>
    </div>

    <div class="container">
        <div class="brand-section">
            <div class="logo">
                <div class="logo-icon"><i class="ri-cloud-line"></i></div>
                <span class="logo-text">CloudDrive</span>
            </div>
            <h1 class="brand-title">Welcome back.</h1>
            <p class="brand-description">Sign in to access your files and manage your cloud storage securely.</p>
            <div class="brand-features">
                <div class="feature-item"><i class="ri-shield-check-line"></i> Enterprise-grade security</div>
                <div class="feature-item"><i class="ri-global-line"></i> Access from anywhere</div>
                <div class="feature-item"><i class="ri-time-line"></i> Instant file sync</div>
            </div>
        </div>

        <div class="form-section">
            <h2 class="form-title">Sign In</h2>
            <p class="form-subtitle">Don't have an account? <a href="/user/register">Create one</a></p>
            <form id="loginForm">
                <div class="form-group">
                    <label class="form-label" for="username">Username</label>
                    <input type="text" id="username" name="username" class="form-input" placeholder="Enter your username" required>
                </div>
                <div class="form-group">
                    <label class="form-label" for="password">Password</label>
                    <input type="password" id="password" name="password" class="form-input" placeholder="Enter your password" required>
                </div>
                <button type="submit" class="submit-btn" id="submitBtn">
                    <span id="btnText">Sign In</span>
                </button>
            </form>
        </div>
    </div>

    <script>
        const toast = document.getElementById('toast');
        const toastIcon = document.getElementById('toastIcon');
        const toastMessage = document.getElementById('toastMessage');

        function showToast(message, type = 'success') {
            toastMessage.textContent = message;
            toastIcon.className = type === 'success' ? 'ri-checkbox-circle-line' : 'ri-error-warning-line';
            toast.className = `toast active ${type}`;
            setTimeout(() => { toast.className = 'toast'; }, 4000);
        }

        document.getElementById('loginForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('submitBtn');
            const text = document.getElementById('btnText');
            btn.disabled = true;
            text.innerHTML = '<div class="spinner"></div> Signing In...';
            const data = Object.fromEntries(new FormData(e.target).entries());
            try {
                const response = await fetch('/user/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                if (response.ok) {
                    showToast('Login successful! Redirecting...', 'success');
                    setTimeout(() => { window.location.href = '/home'; }, 1000);
                } else {
                    const result = await response.json();
                    showToast(result.message || 'Invalid username or password', 'error');
                    btn.disabled = false; text.textContent = 'Sign In';
                }
            } catch (err) {
                showToast('Network error. Please try again.', 'error');
                btn.disabled = false; text.textContent = 'Sign In';
            }
        });
    </script>
</body>
</html>